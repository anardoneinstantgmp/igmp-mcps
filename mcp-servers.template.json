{
  "_comment_about_this_file": "Generic MCP server configuration for InstantGMP. Drop the contents of mcpServers below into your AI client's MCP config (the location varies by client; see docs/clients/*.md). Replace ${IGMP_URL}, ${IGMP_API_USER}, and ${IGMP_API_PASSWORD} with literal values if your client does not expand environment variables. ${IGMP_URL} must NOT include a trailing slash.",

  "mcpServers": {
    "instantgmp-inventory": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/inventory/mcpinventoryserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-setup": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/setup/mcpsetupserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-logs": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/logs/mcplogsserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-ebr": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/ebr/mcpebrserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-qms": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/qms/mcpqmsserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-projects": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/projects/mcpprojectsserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    },
    "instantgmp-docs": {
      "type": "http",
      "url": "${IGMP_URL}/rest/mcpservers/docs/mcpdocsserver",
      "headers": {
        "X-Api-User": "${IGMP_API_USER}",
        "X-Api-Password": "${IGMP_API_PASSWORD}"
      }
    }
  }
}
